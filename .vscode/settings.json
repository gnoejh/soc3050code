{
    "mplab.clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}\\_build\\Main\\Release"
    ],
    "mplab.clangd.path": "",
    "C_Cpp.intelliSenseEngine": "disabled",
    "cmake.sourceDirectory": "W:/soc3050code/cmake/Main/Debug",
    "memory-inspector.debugTypes": [
        "arm-debugger",
        "embedded-debug",
        "gdb",
        "mplab-core-da"
    ],
    "mplab.project.workspace.removeDeletedSourceFiles": "Always",
    "mplab.project.workspace.addNewSourceFiles": "Always",
    "terminal.integrated.env.windows": {
        "PATH": "${env:PATH};C:\\Program Files\\nodejs\\"
    },
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "nodejs.repl.useCodeRepl": true,
    "npm.packageManager": "npm",
    "files.associations": {
        "*.c": "c",
        "*.h": "c",
        "*.hex": "intel-hex",
        "*.elf": "binary"
    },
    "extensions.recommendations": [
        "ms-vscode.vscode-serial-monitor",
        "ms-vscode.cpptools",
        "ms-vscode.powershell"
    ]
}