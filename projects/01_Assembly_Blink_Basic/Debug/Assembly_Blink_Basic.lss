int main_blink_asm(void)
{
    // STEP 1: Configure PORTB as output using assembly
    // Educational note: DDR (Data Direction Register) controls pin direction
    // 0xFF = all pins as output (binary: 11111111)
    asm volatile(
  9e:	0f ef       	ldi	r16, 0xFF	; 255
  a0:	07 bb       	out	0x17, r16	; 23

    // STEP 2: Infinite loop with alternating LED patterns
    while (1)
    {
        // Pattern 1: 0xAA = 10101010 (alternating LEDs)
        asm volatile(
  a2:	0a ea       	ldi	r16, 0xAA	; 170
  a4:	08 bb       	out	0x18, r16	; 24
	#else
		//round up by default
		__ticks_dc = (uint32_t)(ceil(fabs(__tmp)));
	#endif

	__builtin_avr_delay_cycles(__ticks_dc);
  a6:	2f ef       	ldi	r18, 0xFF	; 255
  a8:	83 ed       	ldi	r24, 0xD3	; 211
  aa:	90 e3       	ldi	r25, 0x30	; 48
  ac:	21 50       	subi	r18, 0x01	; 1
  ae:	80 40       	sbci	r24, 0x00	; 0
  b0:	90 40       	sbci	r25, 0x00	; 0
  b2:	e1 f7       	brne	.-8      	; 0xac <main_blink_asm+0xe>
  b4:	00 c0       	rjmp	.+0      	; 0xb6 <main_blink_asm+0x18>
  b6:	00 00       	nop
        );

        _delay_ms(1000); // 1-second delay - creates visible blinking

        // Pattern 2: 0x55 = 01010101 (opposite alternating LEDs)
        asm volatile(
  b8:	05 e5       	ldi	r16, 0x55	; 85
  ba:	08 bb       	out	0x18, r16	; 24
  bc:	2f ef       	ldi	r18, 0xFF	; 255
  be:	83 ed       	ldi	r24, 0xD3	; 211
  c0:	90 e3       	ldi	r25, 0x30	; 48
  c2:	21 50       	subi	r18, 0x01	; 1
